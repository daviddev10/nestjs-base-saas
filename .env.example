# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Base de datos (Supabase) ──────────────────────────
# Lo obtienes en: Supabase → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ─── JWT ───────────────────────────────────────────────
# Genera un string aleatorio seguro, por ejemplo:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=cambia_esto_por_un_secret_seguro
JWT_REFRESH_SECRET=cambia_esto_por_otro_secret_seguro
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email (Nodemailer) ────────────────────────────────
# Para desarrollo puedes usar https://mailtrap.io (gratis)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=tu_usuario_mailtrap
MAIL_PASS=tu_password_mailtrap
MAIL_FROM=noreply@my-saas-app.com

# ─── Supabase Storage ──────────────────────────────────
# Lo obtienes en: Supabase → Settings → API
SUPABASE_URL=https://[REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key
# Clave para crear el primer Super Admin — cámbiala en producción
BOOTSTRAP_SECRET=superusersecretkey 